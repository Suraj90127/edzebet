<body class="hold-transition sidebar-mini">
   <div class="wrapper">
    <%- include('nav') %>
      <div class="content-wrapper">
        <section class="content-header">
          <div class="container-fluid">
            <div class="row mb-2">
              <div class="col-sm-6">
                <h1 class="text-white">Approved Withdrawal</h1>
              </div>
            </div>
          </div>
          <!-- /.container-fluid -->
        </section>
        <div class="mb-3 mx-2">
          <label for="title" class="form-label text-white">Remark</label>
          <input type="text" class="form-control" id="remark" name="title" required placeholder="Enter remark">
        </div>
      <!-- Main content -->
      <section class="content">

        <!-- Default box -->
        <div class="card">
          <div class="card-header">
            <h3 class="card-title">Approve Withdrawal</h3>

            <div class="card-tools">
              <button type="button" class="btn btn-tool" data-card-widget="collapse" title="Collapse">
                <i class="fas fa-minus"></i>
              </button>
              <button type="button" class "btn btn-tool" data-card-widget="remove" title="Remove">
                <i class="fas fa-times"></i>
              </button>
            </div>
          </div>
          <div class="card-body p-0" style="overflow-y: hidden;">
            <table class="table table-striped projects">
              <thead>
                <tr>
                  <th class="text-center">#</th>
                  <th class="text-center">Type</th>
                  <th class="text-center">usdt address</th>
                  <th class="text-center">Account</th>
                  <th class="text-center">Bank</th>
                  <th class="text-center">Account Number</th>
                   <th class="text-center">IFSC Code</th>
                  <th class="text-center">Cardholder Name</th>
                  <th class="text-center">Amount</th>
                  <th class="text-center">Status</th>
                  <th class="text-center">Date</th>
                  <th class="text-center">Action</th>
                </tr>
              </thead>
              <tbody>
                <!-- Withdrawal data will be displayed here -->
              </tbody>
            </table>
          </div>
        </div>

      </section>
    </div>
  </div>
  <script src="/plugins/jquery/jquery.min.js"></script>
  <script src="/plugins/bootstrap/js/bootstrap.bundle.min.js"></script>
  <script src="/dist/js/adminlte.min.js"></script>
  <script src="/js/admin/admin.js"></script>
  <script src="//cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.js"></script>
  <script>
    function show(params) {
      if (params.length == 0) {
        $('tbody').html(`
            <tr class="text-center">
              <td colspan="7">No more data available...</td>
            </tr>
          `);
        return;
      }
      let html = '';
     let show = params.map((data) => {
  html += `<tr class="text-center">
            <td id="row-id-${data.id}">
              ${data.id}
            </td>
            <td id="row-sdt-${data.id}">
              <b>${data.type}</b>
            </td>
            <td id="row-usdt-${data.id}">
              <b>${data.usdt}</b>
            </td>
            <td id="row-phone-${data.id}">
              <b>${data.phone}</b>
            </td>
            <td id="row-name-bank-${data.id}">
              <b>${data.name_bank}</b>
            </td>
            <td id="row-stk-${data.id}" style="min-width: 190px;">
              <b>${data.stk}</b>
            </td>
            <td id="row-ifsc-${data.id}" style="min-width: 190px;">
              <b>${data.ifsc !== '' && data.ifsc !== null ? data.ifsc : ''}</b>
            </td>
            <td id="row-name-user-${data.id}" style="min-width: 190px;">
              <b>${data.name_user}</b>
            </td>
            <td id="row-money-${data.id}">
              <b>${data.type=="USDT"? "$"+Number(data.money/87).toFixed(2):"₹"+data.money}</b>
            </td>
            <td class="project-state">
              <span class="badge badge-warning">Waiting...</span>
            </td>
            <td id="row-today-${data.id}">
              <b>${data.today}</b>
            </td>
            <td class="project-actions text-center" style="min-width: 160px;">
              <!-- Approve -->
                            <a class="btn btn-info btn-sm copy-data" href="javascript:void(0)" data-id="${data.id}">
                <i class="fa fa-copy"></i>
              </a>
              
              <a class="btn btn-success btn-sm confirm-btn" href="" data="${data.id}">
                <i class="fa fa-check"></i>
              </a>
              <!-- Delete -->
              <a class="btn btn-danger btn-sm delete-btn" href="" data="${data.id}">
                <i class="fas fa-trash"></i>
              </a>
            </td>
          </tr>`;
})

          $('tbody').html(html);
          
        
        
        $('.btn-success').click(function (e) { 
  e.preventDefault();
 
    $.ajax({
      type: "POST",
      url: "/api/webapi/admin/withdraw2",
      data: {
        id: id,
        type: 'confirm',
      },
      dataType: "json",
      success: function (response) {
     
     
        if(response.status){
           alert(response.message);
        setTimeout(() => {
          location.reload();
        }, 100);
        
        }else{
           alert(response.message);
        }
        
      },
      error: function (xhr, status, error) {
        alert('Error: Something went wrong. Please try again.');
      }
    });
 
});

        
        
          $('.btn-danger').click(function (e) { 
            e.preventDefault();
            let id = $(this).attr('data');
            let remark = $("#remark").val();
            console.log("object",remark)
            $.ajax({
              type: "POST",
              url: "/api/webapi/admin/withdraw2",
              data: {
                id: id,
                type: 'delete',
                remark:remark
              },
              dataType: "json",
              success: function (response) {
                setTimeout(() => {
                  location.reload();
                }, 100);
                Swal.fire(
                  'Good job!',
                  'You clicked the button!',
                  'success'
                )
              }
            });
          });
    }
 $.ajax({
  type: "POST",
  url: "/api/webapi/admin/recharge",
  data: {},
  dataType: "json",
  success: function (response) {
    show(response.datas3); // Added semicolon
  }
});




document.addEventListener('DOMContentLoaded', function() {
  // Delegate the event to the document or a parent container
  document.addEventListener('click', function(event) {
  console.log("ddd")
    // Check if the clicked element has the class 'copy-data'
    if (event.target.closest('.copy-data')) {
      const button = event.target.closest('.copy-data');
      const id = button.getAttribute('data-id'); // Get the data-id value

      // Extract data from the row
      const sdt = document.getElementById(`row-sdt-${id}`).innerText.trim();
      const usdt = document.getElementById(`row-usdt-${id}`).innerText.trim();
      const phone = document.getElementById(`row-phone-${id}`).innerText.trim();
      const nameBank = document.getElementById(`row-name-bank-${id}`).innerText.trim();
      const stk = document.getElementById(`row-stk-${id}`).innerText.trim();
      const ifsc = document.getElementById(`row-ifsc-${id}`).innerText.trim();
      const nameUser = document.getElementById(`row-name-user-${id}`).innerText.trim();
      const money = document.getElementById(`row-money-${id}`).innerText.trim();
      const today = document.getElementById(`row-today-${id}`).innerText.trim();

      // Concatenate all data into a string
      const dataToCopy = `SDT: ${sdt}\nUSDT: ${usdt}\nPhone: ${phone}\nBank Name: ${nameBank}\nSTK: ${stk}\nIFSC: ${ifsc}\nUser Name: ${nameUser}\nMoney: ${money}\nToday: ${today}`;

      // Copy the data to clipboard
      navigator.clipboard.writeText(dataToCopy).then(() => {
        alert('Data copied to clipboard');
      }).catch(err => {
        console.error('Failed to copy data: ', err);
      });
    }
  });
});



  </script>
</body>

</html>
