<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Settings</title>
    <link rel="stylesheet"
        href="https://fonts.googleapis.com/css?family=Source+Sans+Pro:300,400,400i,700&display=fallback">
    <link rel="stylesheet" href="/plugins/fontawesome-free/css/all.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/4.7.0/css/font-awesome.min.css">
    <link rel="stylesheet" href="/dist/css/adminlte.min.css">
    <link rel="stylesheet" href="/css/admin.css">
    <link href="//cdn.jsdelivr.net/npm/@sweetalert2/theme-dark@4/dark.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/css/bootstrap.min.css" rel="stylesheet"
        integrity="sha384-EVSTQN3/azprG1Anm3QDgpJLIm9Nao0Yz1ztcQTwFspd3yD65VohhpuuCOmLASjC" crossorigin="anonymous">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/axios/1.6.7/axios.min.js"
        integrity="sha512-NQfB/bDaB8kaSXF8E77JjhHG5PM6XVRxvHzkZiwl3ddWCEPBa23T76MuWSwAJdMGJnmQqM0VeY9kFszsrBEFrQ=="
        crossorigin="anonymous" referrerpolicy="no-referrer">
        </script>
    <style>
        .form-group {
            margin-top: 20px;
            padding: 20px;
            border-radius: 5px;
            /* box-shadow: 0 0 5px #2ecc71; */
            background-color: #141b26;
            color: white;
        }

        .form-group button {
            margin-top: 30px;
        }
        
        
       
    
        a {
    color: #007bff;
    text-decoration: none;
    background-color: #192434;
  }
 
    
    
    [class*=sidebar-dark-] .sidebar a {
    color: #9cc6ff;
    background-color: #192434;
}
    



.content-wrapper {
    background-color: #ffff;
}

.card-header {
    background-color: #192434;
    border-bottom: 1px solid rgba(0, 0, 0, .125);
    padding: .75rem 1.25rem;
    position: relative;
    border-top-left-radius: .25rem;
    border-top-right-radius: .25rem;
}

.btn-tool {
    background-color: transparent;
    color: #040404;
    font-size: .875rem;
    margin: -.75rem 0;
    padding: .25rem .5rem;
}


.navbar-dark {
    background-color: #003264;
    border-color: #557b9d;
}


.dark-mode .navbar-dark {
    background-color: #003264;
    border-color: #000000;
}

.nav-sidebar .nav-item>.nav-link {
    margin-bottom: .2rem;
    
}
.content-wrapper{
    background-color: #0e131b;;
}

.card{
  background-color: #141b26;
  color: white;
}

.form-group input{
  background-color: #141b26;
  outline: none;
  border-color: #003264;
  color: white !important;
}
.form-group input:focus{
    background-color: #141b26;
  outline: none;
  border-color: #003264;
  box-shadow: none;
  text-shadow: none;
}

.form-group select{
    background-color: #141b26;
  outline: none;
  border-color: #003264;
  color: white !important;
}
.swal2-popup{
    background-color: 141b26;
}
      </style>
   
</head>

<body class="hold-transition sidebar-mini">
    <div class="wrapper">
        <%- include('nav') %>
            <div class="content-wrapper">
                <section class="content-header">
                    <div class="container-fluid">
                        <div class="row mb-2">
                            <div class="col-sm-6">
                                <h1 class="text-white">Banner Settings </h1>
                            </div>
                        </div>
                    </div>
                    <!-- /.container-fluid -->
                </section>

                <div class="container-fluid">
                    <div class="row">
                        <div class="col-md-12">
                            <div style="padding: 10px 20px;margin-bottom: 200px;">
                 
                         
                    

                                <div class="form-group">
                                             <!---------------------------------------------------------------->
                                    <div class="text-center">
                                        <label for="quantity">Banner Settings</label>
                                    </div>

                                    <label for="" style="color: #3498db;">Banner 1</label>
                                    <input type="text" class="form-control" placeholder="Banner 1"
                                        id="ban1" value=""><br>
                                        <label for="" style="color: #3498db;">Banner 2</label>
                                    <input type="text" class="form-control" placeholder="Banner 2"
                                        id="ban2" value=""><br>
                                        <label for="" style="color: #3498db;">Banner 3</label>
                                    <input type="text" class="form-control" placeholder="Banner 3" id="ban3"
                                        value=""><br>
                                        
                                    <button type="submit" class="btn btn-primary edit-banner"
                                        style="width: 100%;">Submit</button>
                                </div>

                              
                                
                             

                            </div>
                        </div>
                    </div>
                </div>
            </div>
    </div>
    <script src="/plugins/jquery/jquery.min.js"></script>
    <script src="/plugins/bootstrap/js/bootstrap.bundle.min.js"></script>
    <script src="/dist/js/adminlte.min.js"></script>
    <script src="/js/admin/admin.js"></script>
    <script src="//cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.js"></script>
    <script>
    
   
    
    
    
        $.ajax({
            type: "GET",
            url: "/api/webapi/banner",
            data: {},
            dataType: "json",
            success: function (response) {
                let data = response.data;           
                $('#ban1').val(data?.ban1);
                $('#ban2').val(data?.ban2);
                $('#ban3').val(data?.ban3);        
             
            }
        });
    </script>
    <script>
               
      
        $('.edit-banner').click(function (e) {
            e.preventDefault();
            const ban1 = $('#ban1').val();
            const ban2 = $('#ban2').val();
            const ban3 = $('#ban3').val();
            $.ajax({
                type: "POST",
                url: "/api/webapi/banners",
                data: {
                    ban1: ban1,
                    ban2: ban2,
                    ban3: ban3,
                },
                dataType: "json",
                success: function (response) {
                    if (response.status == true) {
                        Swal.fire(
                            'Good job!',
                            'Your Links Updated Successfully!',
                            'success'
                        )
                    } else {
                        Swal.fire({
                            icon: 'error',
                            title: 'Empty or Wrong',
                        })
                    }
                }
            });
        });

        
      
      
    </script>
</body>

</html>